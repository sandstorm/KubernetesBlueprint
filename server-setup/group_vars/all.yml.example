---
# =============================================================================
# K3s Cluster Configuration
# =============================================================================
# Copy this file to all.yml and adjust the values below.
# For Ansible Vault: ansible-vault encrypt_string 'your-secret' --name 'k3s_token'

# ---- REQUIRED ---------------------------------------------------------------

# K3s release version — find releases at https://github.com/k3s-io/k3s/releases
k3s_version: "v1.33.6+k3s1"

# Cluster shared secret — generate with: openssl rand -hex 32
k3s_token: "CHANGE_ME"

# ---- OPTIONAL ----------------------------------------------------------------

# K3s mode: "server" (control plane + worker) or "agent" (worker only)
# k3s_mode: "server"

# Additional K3s CLI arguments (see README.md for common patterns)
# Cilium is the default CNI in this boilerplate — Flannel is disabled.
# NOTE: --disable=servicelb is intentionally NOT included. Disabling servicelb breaks the Rancher
#       management UI. Instead, simply avoid creating LoadBalancer services — servicelb sits idle.
k3s_extra_args: "--cluster-init --disable-network-policy --flannel-backend=none"

# ---- etcdctl (optional) ------------------------------------------------------

# k3s_install_etcdctl: true
# etcdctl_version: "v3.5.0"

# ---- Private Docker Registry (optional) --------------------------------------

# k3s_private_registry_host: "registry.example.com"
# k3s_private_registry_username: "user"
# k3s_private_registry_password: "password"

# =============================================================================
# MariaDB (optional) — auto-generated by `mise run hetzner:create`
# =============================================================================
# Enable MariaDB installation on the host. The root password is auto-generated
# during `mise run hetzner:create` if not already set.
# The database operator must be deployed (mise run cluster-setup:operators)
# before re-running ansible to register the DatabaseServer CRD.

# mariadb_enabled: true
# mariadb_root_password: "CHANGE_ME"
# mariadb_version: "10.11"
# mariadb_operator_server_name: "mariadb1"
# mariadb_operator_connect_host: "{{ ansible_host }}"

# =============================================================================
# PostgreSQL (optional) — auto-generated by `mise run hetzner:create`
# =============================================================================

# postgres_enabled: true
# postgres_root_password: "CHANGE_ME"
# postgres_version: "17"
# postgres_operator_server_name: "postgres1"
# postgres_operator_connect_host: "{{ ansible_host }}"
