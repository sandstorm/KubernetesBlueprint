#!/usr/bin/env bash
#MISE description="Build image for linux/amd64 and import directly into k3s containerd on a node (LOCAL DEV WORKAROUND to work WITHOUT registry)"
#MISE usage="Usage: mise run push-image <image> <node>  # e.g. mise run push-image myapp:dev root@1.2.3.4"
set -euo pipefail

IMAGE="${1:-}"
NODE="${2:-}"

if [ -z "$IMAGE" ] || [ -z "$NODE" ]; then
  echo "Usage: mise run push-image <image> <node>" >&2
  echo "  image  Docker image name and tag, e.g. myapp:dev" >&2
  echo "  node   SSH target of the k3s node, e.g. root@1.2.3.4" >&2
  exit 1
fi

echo ""
gum style --bold "Pushing $IMAGE → $NODE"
echo ""

echo "→ Building $IMAGE for linux/amd64..."
docker buildx build --platform linux/amd64 -t "$IMAGE" --output type=docker .

echo "→ Streaming image to $NODE via SSH..."
docker save "$IMAGE" | ssh "$NODE" "k3s ctr images import -"

echo ""
gum style --foreground 2 "✓ Done!"
echo ""
echo "  Verify:  ssh $NODE 'k3s ctr images list | grep ${IMAGE%%:*}'"
echo "  Reminder: set imagePullPolicy: Never in your manifest"
