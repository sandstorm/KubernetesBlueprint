#!/usr/bin/env bash
#MISE description="Install Cilium CNI via Helm — run BEFORE cluster-setup:apply"
set -euo pipefail

if [ ! -f .cluster.env ]; then
  gum format -- "**Error:** \`.cluster.env\` not found. Run \`mise run hetzner:setup\` first."
  exit 1
fi
source .cluster.env

export KUBECONFIG="$(pwd)/server-setup/kubeconfig"

if [ -z "${CILIUM_VERSION:-}" ]; then
  gum format <<EOM
**Error:** \`CILIUM_VERSION\` is not set in \`.cluster.env\`

Add: \`CILIUM_VERSION="1.18.5"\`

Also ensure k3s was started with \`--flannel-backend=none --disable-network-policy\`
in \`k3s_extra_args\` (\`server-setup/group_vars/all.yml\`) and ansible was re-run.
EOM
  exit 1
fi

# --- Show cluster info as safeguard ---
CLUSTER_SERVER=$(kubectl config view --minify -o jsonpath='{.clusters[0].cluster.server}' 2>/dev/null || echo "unknown")
CLUSTER_NAME=$(kubectl config view --minify -o jsonpath='{.clusters[0].name}' 2>/dev/null || echo "unknown")
CURRENT_CONTEXT=$(kubectl config current-context 2>/dev/null || echo "unknown")

gum format <<EOM

# Cilium CNI Installation

- Cluster: \`${CLUSTER_NAME}\`
- Server: \`${CLUSTER_SERVER}\`
- Context: \`${CURRENT_CONTEXT}\`
- Version: \`${CILIUM_VERSION}\`
- Kubeconfig: \`${KUBECONFIG}\`
EOM
echo ""

gum confirm "Install Cilium ${CILIUM_VERSION} on this cluster?" || exit 0

echo ""

gum spin --title "Adding Cilium Helm repo..." -- \
  bash -c "helm repo add cilium https://helm.cilium.io/ >/dev/null 2>&1 && helm repo update cilium >/dev/null 2>&1"
gum format -- "  ✓ Helm repo ready"

gum spin --title "Installing Cilium ${CILIUM_VERSION}..." -- \
  helm upgrade --install cilium cilium/cilium \
    --version "${CILIUM_VERSION}" \
    --namespace kube-system \
    --set kubeProxyReplacement=true \
    --set ipam.mode=kubernetes \
    --set hubble.relay.enabled=true \
    --set hubble.ui.enabled=true \
    --set localRedirectPolicy=true \
    --set operator.replicas=1
gum format -- "  ✓ Cilium installed"

# --- Wait for Cilium to be ready ---
gum spin --title "Waiting for Cilium DaemonSet to be ready..." -- \
  kubectl rollout status daemonset cilium -n kube-system --timeout=120s

gum format <<EOM

**✓ Cilium installation complete!**

Verify:
\`\`\`
cilium status   # Cluster Pods should show X/X managed by Cilium
\`\`\`

Next: \`mise run cluster-setup:apply\`
EOM
