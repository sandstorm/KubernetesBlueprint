#!/usr/bin/env bash
#MISE description="Deploy operators (onecontaineroneport + database) into the cluster"
set -euo pipefail

if [ ! -f .cluster.env ]; then
  gum style --foreground 1 "Error: .cluster.env not found. Run 'mise run hetzner:setup' first."
  exit 1
fi
source .cluster.env

export KUBECONFIG="$(pwd)/server-setup/kubeconfig"

# --- Show cluster info as safeguard ---
CLUSTER_SERVER=$(kubectl config view --minify -o jsonpath='{.clusters[0].cluster.server}' 2>/dev/null || echo "unknown")
CLUSTER_NAME=$(kubectl config view --minify -o jsonpath='{.clusters[0].name}' 2>/dev/null || echo "unknown")
CURRENT_CONTEXT=$(kubectl config current-context 2>/dev/null || echo "unknown")

echo ""
gum style --bold "Operator Deployment"
echo ""
gum style \
  "  Cluster:    $(gum style --foreground 3 "${CLUSTER_NAME}")" \
  "  Server:     $(gum style --foreground 3 "${CLUSTER_SERVER}")" \
  "  Context:    $(gum style --foreground 3 "${CURRENT_CONTEXT}")" \
  "  Kubeconfig: $(gum style --foreground 3 "${KUBECONFIG}")"
echo ""
echo "  Operators to deploy:"
echo "    - operator-onecontaineroneport  →  ghcr.io/sandstorm/kubernetesblueprint/operator-onecontaineroneport:latest"
echo "    - operator-database             →  ghcr.io/sandstorm/kubernetesblueprint/operator-database:latest"
echo ""

gum confirm "Deploy operators to this cluster?" || exit 0

echo ""

# --- Helper: deploy a single operator ---
deploy_operator() {
  local name="$1"
  local image="$2"
  local namespace="${name}-system"
  local dir="$(pwd)/${name}"

  gum style --bold "  ${name}"

  # Set the controller image
  (cd "${dir}/config/manager" && kustomize edit set image "controller=${image}")

  # Install CRDs
  gum spin --title "  Installing CRDs..." -- \
    bash -c "kustomize build '${dir}/config/crd' | kubectl apply -f -"
  gum style --foreground 2 "    ✓ CRDs applied"

  # Deploy operator
  gum spin --title "  Deploying controller..." -- \
    bash -c "kustomize build '${dir}/config/default' | kubectl apply -f -"
  gum style --foreground 2 "    ✓ Controller deployed to ${namespace}"

  # Wait for rollout
  gum spin --title "  Waiting for rollout..." -- \
    kubectl rollout status deployment -n "${namespace}" --timeout=120s
  gum style --foreground 2 "    ✓ Rollout complete"

  echo ""
}

# --- Deploy operators ---
deploy_operator "operator-onecontaineroneport" "ghcr.io/sandstorm/kubernetesblueprint/operator-onecontaineroneport:latest"
deploy_operator "operator-database" "ghcr.io/sandstorm/kubernetesblueprint/operator-database:latest"

gum style --bold --foreground 2 "✓ All operators deployed!"
echo ""
echo "Verify:"
echo "  export KUBECONFIG=server-setup/kubeconfig"
echo "  kubectl get deployment -n operator-onecontaineroneport-system"
echo "  kubectl get deployment -n operator-database-system"
echo "  kubectl get crd | grep sandstorm"
