#!/usr/bin/env bash
#MISE description="Deploy Rancher UI (optional) — requires cluster-setup:apply to have run first"
set -euo pipefail

if [ ! -f .cluster.env ]; then
  gum format -- "**Error:** \`.cluster.env\` not found. Run \`mise run hetzner:setup\` first."
  exit 1
fi
source .cluster.env

export KUBECONFIG="$(pwd)/server-setup/kubeconfig"

# Default to rancher.${BASE_DOMAIN} if RANCHER_HOSTNAME is not explicitly set
if [ -z "${RANCHER_HOSTNAME:-}" ]; then
  if [ -z "${BASE_DOMAIN:-}" ]; then
    gum format <<EOM
**Error:** Neither \`RANCHER_HOSTNAME\` nor \`BASE_DOMAIN\` is set in \`.cluster.env\`

Add: \`BASE_DOMAIN="k3s.example.com"\` or \`RANCHER_HOSTNAME="rancher.example.com"\`
EOM
    exit 1
  fi
  RANCHER_HOSTNAME="rancher.${BASE_DOMAIN}"
fi
export RANCHER_HOSTNAME

if [ -z "${CERT_MANAGER_EMAIL:-}" ]; then
  gum format <<EOM
**Error:** \`CERT_MANAGER_EMAIL\` is not set in \`.cluster.env\`

Add: \`CERT_MANAGER_EMAIL="admin@example.com"\`
EOM
  exit 1
fi

# --- Show cluster info as safeguard ---
CLUSTER_SERVER=$(kubectl config view --minify -o jsonpath='{.clusters[0].cluster.server}' 2>/dev/null || echo "unknown")
CLUSTER_NAME=$(kubectl config view --minify -o jsonpath='{.clusters[0].name}' 2>/dev/null || echo "unknown")
CURRENT_CONTEXT=$(kubectl config current-context 2>/dev/null || echo "unknown")

gum format <<EOM

# Rancher Deployment

- Cluster: \`${CLUSTER_NAME}\`
- Server: \`${CLUSTER_SERVER}\`
- Context: \`${CURRENT_CONTEXT}\`
- Hostname: \`${RANCHER_HOSTNAME}\`
- Email: \`${CERT_MANAGER_EMAIL}\`
- Kubeconfig: \`${KUBECONFIG}\`
EOM
echo ""

gum confirm "Deploy Rancher to this cluster?" || exit 0

echo ""

gum spin --title "Deploying Rancher (${RANCHER_HOSTNAME})..." -- \
  bash -c "envsubst < cluster-setup/50_rancher.yaml | kubectl apply -f -"
gum format -- "  ✓ Rancher HelmChart applied"

gum format <<EOM

**✓ Rancher deployment initiated!**

Rancher will be available at \`https://${RANCHER_HOSTNAME}\` once the Helm controller finishes.

Verify:
\`\`\`
mise run kubectl get helmchart rancher -n kube-system
mise run kubectl get pods -n cattle-system
\`\`\`
EOM
