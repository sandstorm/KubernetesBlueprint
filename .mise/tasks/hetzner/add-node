#!/usr/bin/env bash
#MISE description="Add a second node to an existing cluster — hcloud only (run hetzner:ansible next)"
set -euo pipefail

if [ ! -f .cluster.env ]; then
  echo "Error: .cluster.env not found. Run 'mise run hetzner:setup' first." >&2
  exit 1
fi
source .cluster.env

P="${CLUSTER_PREFIX}"

hcloud context use "$HCLOUD_CONTEXT"

echo ""
gum format -- "# Adding second node to cluster \`${P}\` (hcloud)"
echo ""

# Read existing node-1 info
echo "→ Reading existing infrastructure..."
NODE1_PUBLIC_IP=$(hcloud server describe "${P}-node-1" -o json | jq -r '.public_net.ipv4.ip')
NODE1_PRIVATE_IP=$(hcloud server describe "${P}-node-1" -o json | jq -r '.private_net[0].ip')
LB_PUBLIC_IP=$(hcloud load-balancer describe "${P}-lb" -o json | jq -r '.public_net.ipv4.ip')
echo "  Node 1 public:  ${NODE1_PUBLIC_IP}"
echo "  Node 1 private: ${NODE1_PRIVATE_IP}"
echo "  LB:             ${LB_PUBLIC_IP}"

# --- Server ---
SERVER_CREATED=0
if hcloud server describe "${P}-node-2" >/dev/null 2>&1; then
  echo "  Server ${P}-node-2 already exists, skipping"
else
  echo "→ Creating server ${P}-node-2 (${SERVER_TYPE} in ${LOCATION})..."
  SERVER_CREATED=1
  hcloud server create \
    --name "${P}-node-2" \
    --type "${SERVER_TYPE}" \
    --image "${OS_IMAGE}" \
    --ssh-key "${SSH_KEY_NAME}" \
    --network "${P}-network" \
    --firewall "${P}-firewall" \
    --location "${LOCATION}"
fi

NODE2_PUBLIC_IP=$(hcloud server describe "${P}-node-2" -o json | jq -r '.public_net.ipv4.ip')
NODE2_PRIVATE_IP=$(hcloud server describe "${P}-node-2" -o json | jq -r '.private_net[0].ip')
echo "  Node 2 public:  ${NODE2_PUBLIC_IP}"
echo "  Node 2 private: ${NODE2_PRIVATE_IP}"

# --- LB target ---
LB_TARGETS=$(hcloud load-balancer describe "${P}-lb" -o json | jq -r '.targets[].server.name // empty')
if echo "$LB_TARGETS" | grep -qx "${P}-node-2"; then
  echo "  ${P}-node-2 already a LB target, skipping"
else
  echo "→ Adding ${P}-node-2 to load balancer..."
  hcloud load-balancer add-target "${P}-lb" \
    --server "${P}-node-2" \
    --use-private-ip
fi

# --- Regenerate inventory with both nodes ---
echo "→ Regenerating server-setup/inventory/hosts.yml..."
cat > server-setup/inventory/hosts.yml <<INVENTORY
---
all:
  hosts:
    ${P}-node-1:
      ansible_host: ${NODE1_PUBLIC_IP}
      ansible_user: root
      ansible_port: 22
      k3s_private_ip: "${NODE1_PRIVATE_IP}"
      # NOTE: disabling network-policy/flannel, as we want to use cilium
      k3s_extra_args: "--cluster-init --tls-san ${NODE1_PUBLIC_IP} --disable-network-policy --flannel-backend=none"
    ${P}-node-2:
      ansible_host: ${NODE2_PUBLIC_IP}
      ansible_user: root
      ansible_port: 22
      k3s_private_ip: "${NODE2_PRIVATE_IP}"
      # NOTE: disabling network-policy/flannel, as we want to use cilium
      k3s_extra_args: "--server https://${NODE1_PRIVATE_IP}:6443 --tls-san ${NODE2_PUBLIC_IP} --disable-network-policy --flannel-backend=none"
INVENTORY

gum format <<EOM

**✓ Node 2 ready!**

- Node 2: \`ssh root@${NODE2_PUBLIC_IP}\`

Now run Ansible to install k3s on node-2:
\`\`\`
mise run hetzner:ansible -- --limit ${P}-node-2
\`\`\`
EOM
