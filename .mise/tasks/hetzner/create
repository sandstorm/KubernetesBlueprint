#!/usr/bin/env bash
#MISE description="Create single-node k3s cluster on Hetzner Cloud (Variant 1: node + LB + firewall)"
set -euo pipefail

if [ ! -f .cluster.env ]; then
  echo "Error: .cluster.env not found. Run 'mise run setup' first." >&2
  exit 1
fi
source .cluster.env

P="${CLUSTER_PREFIX}"

hcloud context use "$HCLOUD_CONTEXT"

echo ""
gum format -- "# Creating Hetzner Cloud resources (prefix: \`${P}\`)"
echo ""

# --- Network ---
if hcloud network describe "${P}-network" >/dev/null 2>&1; then
  echo "  Network ${P}-network already exists, skipping"
else
  echo "→ Creating private network ${P}-network (10.208.183.0/24)..."
  hcloud network create --name "${P}-network" --ip-range 10.208.183.0/24
  hcloud network add-subnet "${P}-network" \
    --network-zone eu-central \
    --type server \
    --ip-range 10.208.183.0/24
fi

# --- Firewall ---
if hcloud firewall describe "${P}-firewall" >/dev/null 2>&1; then
  echo "  Firewall ${P}-firewall already exists, skipping"
else
  echo "→ Creating firewall ${P}-firewall..."
  hcloud firewall create --name "${P}-firewall"
  hcloud firewall add-rule "${P}-firewall" \
    --direction in --protocol tcp --port 22 \
    --source-ips 0.0.0.0/0 --source-ips ::/0 \
    --description "SSH"
  hcloud firewall add-rule "${P}-firewall" \
    --direction in --protocol tcp --port 80 \
    --source-ips 0.0.0.0/0 --source-ips ::/0 \
    --description "HTTP"
  hcloud firewall add-rule "${P}-firewall" \
    --direction in --protocol tcp --port 443 \
    --source-ips 0.0.0.0/0 --source-ips ::/0 \
    --description "HTTPS"
  # WARNING: This exposes the Kubernetes API server to the public internet.
  # It is required so you can run kubectl from your local machine or CI/CD pipelines.
  # The API is protected by TLS and the cluster token, but for a tighter security posture
  # replace 0.0.0.0/0 and ::/0 below with your own IP address(es).
  hcloud firewall add-rule "${P}-firewall" \
    --direction in --protocol tcp --port 6443 \
    --source-ips 0.0.0.0/0 --source-ips ::/0 \
    --description "Kubernetes API (kubectl) — public! restrict to your IPs if possible"
fi

# --- Primary IP for node-1 (survives server deletion → stable DNS) ---
DATACENTER=$(hcloud datacenter list -o json | jq -r --arg loc "$LOCATION" \
  '[.[] | select(.location.name == $loc)][0].name')
if hcloud primary-ip describe "${P}-node-1-ipv4" >/dev/null 2>&1; then
  echo "  Primary IP ${P}-node-1-ipv4 already exists, reusing"
else
  echo "→ Creating primary IP ${P}-node-1-ipv4 in ${DATACENTER}..."
  hcloud primary-ip create --name "${P}-node-1-ipv4" --type ipv4 \
    --datacenter "${DATACENTER}" --assignee-type server
fi

# --- Server ---
SERVER_CREATED=0
if hcloud server describe "${P}-node-1" >/dev/null 2>&1; then
  echo "  Server ${P}-node-1 already exists, skipping"
else
  echo "→ Creating server ${P}-node-1 (${SERVER_TYPE} in ${LOCATION})..."
  SERVER_CREATED=1
  hcloud server create \
    --name "${P}-node-1" \
    --type "${SERVER_TYPE}" \
    --image "${OS_IMAGE}" \
    --ssh-key "${SSH_KEY_NAME}" \
    --network "${P}-network" \
    --firewall "${P}-firewall" \
    --location "${LOCATION}" \
    --primary-ipv4 "${P}-node-1-ipv4"
fi

NODE1_PUBLIC_IP=$(hcloud server describe "${P}-node-1" -o json | jq -r '.public_net.ipv4.ip')
NODE1_PRIVATE_IP=$(hcloud server describe "${P}-node-1" -o json | jq -r '.private_net[0].ip')
echo "  Node 1 public:  ${NODE1_PUBLIC_IP}"
echo "  Node 1 private: ${NODE1_PRIVATE_IP}"

# --- Load Balancer ---
if hcloud load-balancer describe "${P}-lb" >/dev/null 2>&1; then
  echo "  Load balancer ${P}-lb already exists"
  # Ensure node-1 is a target (may be stale after server recreation)
  if hcloud load-balancer add-target "${P}-lb" \
       --server "${P}-node-1" \
       --use-private-ip 2>/dev/null; then
    echo "→ Added ${P}-node-1 to load balancer"
  else
    echo "  ${P}-node-1 already a LB target"
  fi
else
  echo "→ Creating load balancer ${P}-lb..."
  hcloud load-balancer create \
    --name "${P}-lb" \
    --type lb11 \
    --location "${LOCATION}"

  hcloud load-balancer attach-to-network "${P}-lb" \
    --network "${P}-network" \
    --ip 10.208.183.100

  hcloud load-balancer add-target "${P}-lb" \
    --server "${P}-node-1" \
    --use-private-ip

  hcloud load-balancer add-service "${P}-lb" \
    --protocol tcp --listen-port 80 --destination-port 80 \
    --proxy-protocol \
    --health-check-interval 3s --health-check-timeout 1s --health-check-retries 1
  hcloud load-balancer add-service "${P}-lb" \
    --protocol tcp --listen-port 443 --destination-port 443 \
    --proxy-protocol \
    --health-check-interval 3s --health-check-timeout 1s --health-check-retries 1
fi

LB_PUBLIC_IP=$(hcloud load-balancer describe "${P}-lb" -o json | jq -r '.public_net.ipv4.ip')
echo "  Load Balancer:  ${LB_PUBLIC_IP}"

# --- Generate Ansible files ---
echo "→ Generating server-setup/inventory/hosts.yml..."
mkdir -p server-setup/inventory
cat > server-setup/inventory/hosts.yml <<INVENTORY
---
all:
  hosts:
    ${P}-node-1:
      ansible_host: ${NODE1_PUBLIC_IP}
      ansible_user: root
      ansible_port: 22
      k3s_private_ip: "${NODE1_PRIVATE_IP}"
      # NOTE: disabling network-policy/flannel, as we want to use cilium
      k3s_extra_args: "--cluster-init --tls-san ${NODE1_PUBLIC_IP} --disable-network-policy --flannel-backend=none"
INVENTORY

echo "→ Generating server-setup/group_vars/all.yml..."
mkdir -p server-setup/group_vars

# --- Auto-generate database root passwords if enabled and not already set ---
DB_VARS=""
if [ "${MARIADB_ENABLED:-false}" = "true" ]; then
  # Preserve existing password if all.yml already has one
  EXISTING_MARIADB_PW=""
  if [ -f server-setup/group_vars/all.yml ]; then
    EXISTING_MARIADB_PW=$(grep '^mariadb_root_password:' server-setup/group_vars/all.yml | sed 's/^mariadb_root_password: *"\(.*\)"/\1/' || true)
  fi
  if [ -z "$EXISTING_MARIADB_PW" ]; then
    EXISTING_MARIADB_PW=$(openssl rand -hex 24)
    echo "  Generated MariaDB root password."
  else
    echo "  Reusing existing MariaDB root password."
  fi
  DB_VARS="${DB_VARS}
mariadb_enabled: true
mariadb_root_password: \"${EXISTING_MARIADB_PW}\""
fi

if [ "${POSTGRES_ENABLED:-false}" = "true" ]; then
  EXISTING_POSTGRES_PW=""
  if [ -f server-setup/group_vars/all.yml ]; then
    EXISTING_POSTGRES_PW=$(grep '^postgres_root_password:' server-setup/group_vars/all.yml | sed 's/^postgres_root_password: *"\(.*\)"/\1/' || true)
  fi
  if [ -z "$EXISTING_POSTGRES_PW" ]; then
    EXISTING_POSTGRES_PW=$(openssl rand -hex 24)
    echo "  Generated PostgreSQL root password."
  else
    echo "  Reusing existing PostgreSQL root password."
  fi
  DB_VARS="${DB_VARS}
postgres_enabled: true
postgres_root_password: \"${EXISTING_POSTGRES_PW}\""
fi

cat > server-setup/group_vars/all.yml <<GROUPVARS
---
k3s_version: "${K3S_VERSION}"
k3s_token: "${K3S_TOKEN}"${DB_VARS}
GROUPVARS

# --- Update SSH known_hosts if server was freshly created ---
if [ "$SERVER_CREATED" -eq 1 ]; then
  echo ""
  echo "→ Waiting a few seconds for SSH to become available..."
  sleep 5
  mise run hetzner:ssh-keyscan
fi

gum format <<EOM

**✓ Infrastructure ready!**

- Node 1: \`ssh root@${NODE1_PUBLIC_IP}\`
- Load Balancer: \`${LB_PUBLIC_IP}\` (ports 80, 443)

Next: \`mise run hetzner:ansible\`
EOM
