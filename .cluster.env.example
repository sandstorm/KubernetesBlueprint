# Copy to .cluster.env and fill in your values, or run: mise run setup
HCLOUD_CONTEXT="my-project"
CLUSTER_PREFIX="k3s"
SSH_KEY_NAME="my-ssh-key"
SERVER_TYPE="cx22"
LOCATION="nbg1"
OS_IMAGE="ubuntu-24.04"
K3S_VERSION="v1.33.6+k3s1"
K3S_TOKEN="CHANGE_ME"

# Base domain for apps — set up a wildcard CNAME: *.k3s.example.com → load balancer IP
# Apps will be reachable at <app>.BASE_DOMAIN (e.g., excalidraw.k3s.example.com)
BASE_DOMAIN="k3s.example.com"

# Email for Let's Encrypt certificate registration (used by cert-manager)
CERT_MANAGER_EMAIL="admin@example.com"

# Cilium CNI version — install BEFORE cluster-setup:apply with: mise run cluster-setup:cilium
CILIUM_VERSION="1.18.5"

# Rancher UI (optional) — override to use a custom domain instead of rancher.${BASE_DOMAIN}
# RANCHER_HOSTNAME="rancher.example.com"

# Database servers installed on the host (both enabled by default)
MARIADB_ENABLED="true"
POSTGRES_ENABLED="true"
